# Leaf Health Check - Environment Configuration
# Copy this file to .env and fill in your values

# Database
DB_PATH=database/plants.db

# Model
MODEL_ARCHITECTURE=efficientnet
MODEL_PATH=model/

# Image Processing
TARGET_IMAGE_SIZE=224
MAX_IMAGE_SIZE_MB=25

# Streamlit
STREAMLIT_SERVER_MAXUPLOADSIZE=25
STREAMLIT_LOGGER_LEVEL=INFO

# Google Gemini AI Configuration
GOOGLE_GEMINI_API_KEY=AIzaSyCbFF4dKddz8XtAvnLvOCo2cgUawcAkJwU
GEMINI_MODEL=gemini-pro
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=1000

# API Configuration (if deployed as REST API)
API_HOST=0.0.0.0
API_PORT=8000

# Optional: Twilio SMS Alerts (for critical recommendations)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890
